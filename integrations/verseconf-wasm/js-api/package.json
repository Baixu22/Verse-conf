{
  "name": "verseconf",
  "version": "0.1.0",
  "description": "VerseConf - Modern configuration format for the AI era",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./wasm": "./pkg/verseconf_wasm_bg.wasm"
  },
  "files": [
    "dist",
    "pkg"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "npm run build:wasm && npm run build:ts && npm run copy:wasm",
    "build:wasm": "cd .. && wasm-pack build --target nodejs --out-dir js-api/pkg",
    "build:ts": "tsc",
    "copy:wasm": "node -e \"require('fs').copyFileSync('pkg/verseconf_wasm_bg.wasm', 'dist/verseconf.wasm')\"",
    "test": "jest",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "config",
    "configuration",
    "parser",
    "wasm",
    "verseconf"
  ],
  "author": "VerseConf Team",
  "license": "MIT OR Apache-2.0",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.10",
    "ts-jest": "^29.1.1"
  }
}

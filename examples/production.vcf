# VerseConf Production Example
# A comprehensive example for production use

@include "common/defaults.vcf" merge=deep_merge

app {
    name = "ProductionService"
    version = "2.0.0"
    environment = "production"
    
    # Server configuration
    server {
        host = "0.0.0.0"
        port = 8443 #@ range(1024..65535), description="HTTPS port"
        workers = 4 #@ range(1..32), type_hint="int"
        
        ssl {
            enabled = true
            cert = "/etc/ssl/certs/app.pem" #@ required, description="SSL certificate"
            key = "/etc/ssl/private/app.key" #@ sensitive, required, description="SSL private key"
        }
        
        cors {
            allowed_origins = ["https://app.example.com"]
            allowed_methods = ["GET", "POST", "PUT", "DELETE"]
            max_age = 86400s
        }
    }
    
    # Database configuration
    database {
        primary {
            host = "${DB_PRIMARY_HOST}" #@ required
            port = 5432 #@ range(1024..65535)
            name = "${DB_NAME}" #@ required
            pool_size = 20 #@ range(5..100), type_hint="int"
            
            credentials {
                user = "${DB_USER}" #@ required
                password = "${DB_PASS}" #@ sensitive, required
            }
        }
        
        replica {
            host = "${DB_REPLICA_HOST|}"
            port = 5432
            read_only = true
        }
    }
    
    # Cache configuration
    redis {
        host = "${REDIS_HOST|localhost}"
        port = 6379 #@ range(1024..65535)
        db = 0 #@ range(0..15), type_hint="int"
        password = "${REDIS_PASS}" #@ sensitive
        timeout = 5s #@ range(1..30)
    }
    
    # Message queue
    rabbitmq {
        host = "${RABBITMQ_HOST|localhost}"
        port = 5672
        vhost = "/production"
        credentials {
            user = "${RABBITMQ_USER}" #@ required
            password = "${RABBITMQ_PASS}" #@ sensitive, required
        }
    }
    
    # Feature flags
    features = [
        "auth",
        "rate_limiting",
        "caching",
        "monitoring",
        "tracing",
    ]
    
    # Logging
    logging {
        level = "warn" #@ type_hint="string", example="debug|info|warn|error"
        format = "json"
        outputs = ["stdout", "file"]
        
        file {
            path = "/var/log/app/service.log"
            max_size = 100MB
            rotation = "daily"
        }
    }
    
    # Monitoring
    monitoring {
        enabled = true
        metrics_endpoint = "/metrics"
        health_endpoint = "/health"
        
        prometheus {
            enabled = true
            port = 9090 #@ range(1024..65535)
        }
        
        alerts {
            email = ["ops@example.com"]
            slack_channel = "#alerts-production"
        }
    }
    
    # Rate limiting
    rate_limit {
        enabled = true
        requests_per_minute = 100 #@ range(10..1000), type_hint="int"
        burst_size = 20 #@ range(5..100), type_hint="int"
    }
}

# Include environment-specific overrides
@include "environments/production.vcf" merge=deep_merge
